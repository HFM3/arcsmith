# --- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
*.egg

# Packaging / build output
build/
dist/
wheels/
*.whl
*.tar.gz
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

